{
  "name": "desktop-ai-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "tauri": "tauri",
    "live2d:chrome": "google-chrome --app=http://127.0.0.1:1420/live2d.html --window-size=400,540 --enable-features=VaapiVideoDecoder",
    "live2d:electron": "vite --host 127.0.0.1 & VITE_PID=$!; trap 'kill $VITE_PID 2>/dev/null' EXIT INT TERM; cd live2d-electron && npm start",
    "live2d:electron:software": "vite --host 127.0.0.1 & VITE_PID=$!; trap 'kill $VITE_PID 2>/dev/null' EXIT INT TERM; cd live2d-electron && npm run start:software"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.0.0",
    "@tauri-apps/plugin-http": "^2.0.0",
    "lucide-react": "^0.468.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0"
  },
  "overrides": {
    "pixi-live2d-display": {
      "gh-pages": "6.3.0"
    }
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.2.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.5.4",
    "vite": "^6.4.3"
  }
}
