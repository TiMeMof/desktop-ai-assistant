# Live2D model URL — path to the .model3.json relative to public/ or an absolute URL
# Example with bundled Haru model:
# VITE_LIVE2D_MODEL_URL=/live2d/models/haru/haru_greeter_t03.model3.json
# Example with CDN model:
# VITE_LIVE2D_MODEL_URL=https://cdn.jsdelivr.net/gh/guansss/pixi-live2d-display/test/assets/haru/haru_greeter_t03.model3.json
VITE_LIVE2D_MODEL_URL=

# Cubism Core runtime URL — live2dcubismcore.min.js
# Option A: CDN (works without local file)
VITE_LIVE2D_CORE_URL=https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js
# Option B: Local file (download from https://cubism.live2d.com/sdk-download/cubismsdk4web/)
# VITE_LIVE2D_CORE_URL=/live2d/cubismcore/live2dcubismcore.min.js
